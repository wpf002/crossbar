# Database
DATABASE_URL=postgresql://crossbar:crossbar@localhost:5432/crossbar

# Redis (live order book state)
REDIS_URL=redis://localhost:6379

# Service ports
API_PORT=4000
WEB_PORT=3000
MATCHER_PORT=4100

# Auth
JWT_SECRET=change_me_to_a_long_random_string

# Sports data
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports

# Resolver
RESOLVER_POLL_SECONDS=60
# Fast re-poll cadence for in-progress games (seconds, clamped 5–60).
LIVE_POLL_SECONDS=10
# Auto-generate player-prop markets from live box scores (high volume; opt-in).
PLAYER_PROPS_AUTOGEN=false
# Auto-generate per-period winner markets for live games (set false to disable).
LIVE_PERIOD_MARKETS=true
